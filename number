<!doctype html>
<html lang="ro">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Roata Norocului Auto</title>
    <style>
      :root {
        --black: #050505;
        --ink: #0b0b0b;
        --white: #fff;
        --muted: rgba(255, 255, 255, 0.72);
        --line: rgba(255, 255, 255, 0.18);
        --glass: rgba(7, 7, 7, 0.76);
        --red: #d7192d;
        --red-deep: #720914;
        --gold: #d8b276;
        --gold-soft: #f0d19a;
        --neon: #39ff88;
        --neon-deep: #062d1a;
      }

      * {
        box-sizing: border-box;
      }

      html,
      body {
        min-height: 100%;
      }

      body {
        margin: 0;
        background:
          linear-gradient(90deg, rgba(0, 0, 0, 0.94), rgba(0, 0, 0, 0.66), rgba(0, 0, 0, 0.9)),
          url("assets/game-crystal-keys.jpg") center / cover fixed;
        color: var(--white);
        font-family: Avenir, "Avenir Next", Arial, sans-serif;
      }

      .app {
        position: relative;
        min-height: 100svh;
        overflow: hidden;
        isolation: isolate;
      }

      .app::before {
        content: "";
        position: absolute;
        inset: 0;
        z-index: -2;
        background:
          radial-gradient(circle at 67% 34%, rgba(57, 255, 136, 0.22), transparent 31%),
          radial-gradient(circle at 20% 78%, rgba(57, 255, 136, 0.14), transparent 34%),
          repeating-linear-gradient(120deg, rgba(255, 255, 255, 0.035) 0 1px, transparent 1px 18px);
      }

      .app::after {
        content: "";
        position: absolute;
        inset: auto -15% -26% -15%;
        z-index: -1;
        height: 42%;
        background: radial-gradient(ellipse at center, rgba(215, 25, 45, 0.38), transparent 64%);
        filter: blur(14px);
      }

      .top {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        padding: max(18px, env(safe-area-inset-top)) 22px 0;
      }

      .brand,
      .attempt {
        min-height: 42px;
        display: flex;
        align-items: center;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(0, 0, 0, 0.58);
        backdrop-filter: blur(14px);
        box-shadow: 0 16px 38px rgba(0, 0, 0, 0.34);
      }

      .brand {
        padding: 0 16px;
        border-radius: 12px;
        font-size: 15px;
        font-weight: 950;
        letter-spacing: 1.1px;
        text-transform: uppercase;
      }

      .attempt {
        padding: 0 15px;
        color: var(--ink);
        background: var(--white);
        font-weight: 950;
      }

      .layout {
        width: min(1220px, 100%);
        min-height: calc(100svh - 62px);
        margin: 0 auto;
        padding: 18px 22px 24px;
        display: grid;
        grid-template-columns: 0.88fr 1.12fr;
        gap: 24px;
        align-items: center;
      }

      .intro {
        display: grid;
        gap: 18px;
      }

      .eyebrow {
        width: fit-content;
        padding: 9px 12px;
        border: 1px solid rgba(57, 255, 136, 0.45);
        border-radius: 999px;
        background: rgba(57, 255, 136, 0.1);
        color: var(--neon);
        font-size: 13px;
        font-weight: 950;
        letter-spacing: 1px;
        text-transform: uppercase;
      }

      h1 {
        max-width: 540px;
        margin: 0;
        font-family: "Bodoni 72", "Bodoni 72 Oldstyle", Georgia, serif;
        font-size: clamp(54px, 8vw, 98px);
        line-height: 0.88;
      }

      .lead {
        max-width: 500px;
        margin: 0;
        color: var(--muted);
        font-size: 18px;
        line-height: 1.45;
      }

      .steps {
        display: grid;
        gap: 10px;
        max-width: 500px;
      }

      .step {
        display: flex;
        gap: 12px;
        align-items: center;
        min-height: 42px;
        color: rgba(255, 255, 255, 0.9);
        font-weight: 850;
      }

      .step span {
        width: 34px;
        height: 34px;
        display: grid;
        flex: 0 0 auto;
        place-items: center;
        border-radius: 50%;
        background: #fff;
        color: #111;
        font-weight: 950;
      }

      .top-gallery {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 10px;
        margin-bottom: 16px;
      }

      .top-gallery .photo {
        position: relative;
        overflow: hidden;
        aspect-ratio: 1.08 / 1;
        border: 1px solid var(--line);
        border-radius: 14px;
        background: #111;
        box-shadow: 0 16px 34px rgba(0, 0, 0, 0.36);
      }

      .top-gallery .photo img {
        width: 100%;
        height: 100%;
        display: block;
        object-fit: cover;
      }

      .wheel-zone {
        display: grid;
        place-items: center;
      }

      .wheel-card {
        width: min(650px, 100%);
        padding: 22px;
        border: 1px solid var(--line);
        border-radius: 24px;
        background:
          linear-gradient(145deg, rgba(255, 255, 255, 0.08), rgba(255, 255, 255, 0.02)),
          var(--glass);
        backdrop-filter: blur(14px);
        box-shadow: 0 34px 86px rgba(0, 0, 0, 0.58);
      }

      .wheel-head {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        align-items: center;
        margin-bottom: 14px;
      }

      .wheel-head strong {
        font-size: 20px;
        font-weight: 950;
      }

      .status {
        padding: 8px 11px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.1);
        color: var(--muted);
        font-size: 13px;
        font-weight: 850;
      }

      .wheel-wrap {
        position: relative;
        width: min(82vw, 520px);
        aspect-ratio: 1;
        margin: 0 auto;
      }

      .pointer {
        position: absolute;
        z-index: 6;
        top: -8px;
        left: 50%;
        width: 0;
        height: 0;
        transform: translateX(-50%);
        border-left: 23px solid transparent;
        border-right: 23px solid transparent;
        border-top: 52px solid #fff;
        filter: drop-shadow(0 6px 12px rgba(0, 0, 0, 0.5));
      }

      .wheel {
        position: absolute;
        inset: 0;
        border: 11px solid rgba(57, 255, 136, 0.86);
        border-radius: 50%;
        background:
          radial-gradient(circle at center, transparent 0 18%, rgba(0, 0, 0, 0.22) 18% 19%, transparent 19%),
          conic-gradient(
            from -22.5deg,
            #050505 0deg 45deg,
            #39ff88 45deg 90deg,
            #050505 90deg 135deg,
            #39ff88 135deg 180deg,
            #050505 180deg 225deg,
            #39ff88 225deg 270deg,
            #050505 270deg 315deg,
            #39ff88 315deg 360deg
          );
        box-shadow:
          inset 0 0 0 7px rgba(0, 0, 0, 0.28),
          inset 0 0 36px rgba(0, 0, 0, 0.34),
          0 24px 62px rgba(0, 0, 0, 0.55),
          0 0 28px rgba(57, 255, 136, 0.4),
          0 0 76px rgba(57, 255, 136, 0.16);
        transform: rotate(0deg);
        transition: transform 5s cubic-bezier(0.1, 0.74, 0.11, 1);
        animation: wheelGlow 2.4s ease-in-out infinite;
      }

      .wheel::after {
        content: "";
        position: absolute;
        inset: 7%;
        border: 1px solid rgba(255, 255, 255, 0.24);
        border-radius: 50%;
        pointer-events: none;
      }

      .slice-label {
        position: absolute;
        left: 50%;
        top: 50%;
        width: 46%;
        height: 34px;
        margin-top: -17px;
        transform-origin: left center;
        display: flex;
        align-items: center;
        justify-content: flex-end;
        padding-right: 10px;
        color: #fff;
        font-size: 21px;
        font-weight: 950;
        text-shadow: 0 2px 7px rgba(0, 0, 0, 0.8);
        white-space: nowrap;
      }

      .slice-label:nth-child(1) { transform: rotate(22.5deg); }
      .slice-label:nth-child(2) { transform: rotate(67.5deg); }
      .slice-label:nth-child(3) { transform: rotate(112.5deg); }
      .slice-label:nth-child(2),
      .slice-label:nth-child(4),
      .slice-label:nth-child(6),
      .slice-label:nth-child(8) {
        color: #fff;
        text-shadow: 0 2px 7px rgba(0, 0, 0, 0.8);
      }

      .slice-label:nth-child(4) { transform: rotate(157.5deg); }
      .slice-label:nth-child(5) { transform: rotate(202.5deg); }
      .slice-label:nth-child(6) { transform: rotate(247.5deg); }
      .slice-label:nth-child(7) { transform: rotate(292.5deg); }
      .slice-label:nth-child(8) { transform: rotate(337.5deg); }

      .hub {
        position: absolute;
        z-index: 5;
        inset: 50% auto auto 50%;
        width: 118px;
        height: 118px;
        display: grid;
        place-items: center;
        transform: translate(-50%, -50%);
        border: 7px solid rgba(255, 255, 255, 0.94);
        border-radius: 50%;
        background: #080808;
        color: var(--neon);
        font-weight: 950;
        letter-spacing: 1px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.48);
      }

      .controls {
        display: grid;
        gap: 12px;
        margin-top: 18px;
      }

      .lead-form {
        display: grid;
        gap: 10px;
        padding: 14px;
        border: 1px solid rgba(57, 255, 136, 0.28);
        border-radius: 18px;
        background: rgba(0, 0, 0, 0.36);
      }

      .lead-form.hidden {
        display: none;
      }

      .lead-form label {
        display: grid;
        gap: 6px;
        color: rgba(255, 255, 255, 0.84);
        font-size: 13px;
        font-weight: 850;
      }

      .lead-form input {
        width: 100%;
        min-height: 48px;
        border: 1px solid rgba(255, 255, 255, 0.18);
        border-radius: 14px;
        background: rgba(255, 255, 255, 0.08);
        color: #fff;
        font: inherit;
        font-size: 16px;
        font-weight: 750;
        outline: none;
        padding: 0 14px;
      }

      .lead-form input:focus {
        border-color: rgba(57, 255, 136, 0.72);
        box-shadow: 0 0 0 3px rgba(57, 255, 136, 0.12);
      }

      .lead-form input::placeholder {
        color: rgba(255, 255, 255, 0.42);
      }

      .form-note,
      .form-error,
      .lead-summary {
        font-size: 12px;
        font-weight: 800;
        line-height: 1.35;
      }

      .form-note {
        color: rgba(255, 255, 255, 0.6);
      }

      .form-error {
        display: none;
        color: #ff9aa5;
      }

      .form-error.show {
        display: block;
      }

      .lead-summary {
        display: none;
        padding: 12px 14px;
        border: 1px solid rgba(57, 255, 136, 0.28);
        border-radius: 16px;
        background: rgba(57, 255, 136, 0.09);
        color: rgba(255, 255, 255, 0.86);
        text-align: center;
      }

      .lead-summary.show {
        display: block;
      }

      button {
        min-height: 60px;
        border: 0;
        border-radius: 999px;
        background: #fff;
        color: #090909;
        font: inherit;
        font-size: 18px;
        font-weight: 950;
        cursor: pointer;
      }

      button:disabled {
        cursor: default;
        opacity: 0.74;
      }

      .result {
        display: none;
        padding: 18px;
        border: 1px solid rgba(57, 255, 136, 0.58);
        border-radius: 18px;
        background:
          linear-gradient(145deg, rgba(57, 255, 136, 0.16), rgba(57, 255, 136, 0.06)),
          rgba(0, 0, 0, 0.4);
        text-align: center;
      }

      .result.show {
        display: block;
      }

      .result span {
        display: block;
        color: var(--muted);
        font-size: 14px;
        font-weight: 900;
        text-transform: uppercase;
      }

      .result strong {
        display: block;
        margin: 7px 0;
        color: #fff;
        font-size: clamp(26px, 5vw, 36px);
        line-height: 1.05;
      }

      .result b {
        display: inline-flex;
        min-height: 44px;
        align-items: center;
        justify-content: center;
        padding: 0 14px;
        border-radius: 999px;
        background: var(--neon);
        color: #111;
        font-size: 22px;
        font-weight: 950;
        letter-spacing: 1px;
      }

      .ig-link {
        min-height: 56px;
        display: none;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(57, 255, 136, 0.42);
        border-radius: 999px;
        background: rgba(57, 255, 136, 0.12);
        color: #fff;
        font-size: 17px;
        font-weight: 950;
        text-align: center;
        text-decoration: none;
        box-shadow: 0 0 24px rgba(57, 255, 136, 0.16);
      }

      .ig-link.show {
        display: flex;
      }

      .copy-hint {
        display: none;
        margin-top: -4px;
        color: rgba(255, 255, 255, 0.72);
        font-size: 12px;
        font-weight: 800;
        line-height: 1.35;
        text-align: center;
      }

      .copy-hint.show {
        display: block;
      }

      .note {
        color: var(--muted);
        font-size: 13px;
        line-height: 1.45;
        text-align: center;
      }

      .locked {
        display: none;
        padding: 14px;
        border: 1px solid rgba(255, 255, 255, 0.2);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.82);
        text-align: center;
        font-weight: 800;
        line-height: 1.4;
      }

      .locked.show {
        display: block;
      }

      .spark {
        position: fixed;
        z-index: 20;
        top: -18px;
        width: 8px;
        height: 18px;
        border-radius: 999px;
        background: var(--neon);
        box-shadow: 0 0 16px rgba(57, 255, 136, 0.8);
        pointer-events: none;
        animation: fallSpark 1.45s ease-in forwards;
      }

      @keyframes wheelGlow {
        0%, 100% {
          box-shadow:
            inset 0 0 0 7px rgba(0, 0, 0, 0.28),
            inset 0 0 36px rgba(0, 0, 0, 0.34),
            0 24px 62px rgba(0, 0, 0, 0.55),
            0 0 24px rgba(57, 255, 136, 0.32),
            0 0 64px rgba(57, 255, 136, 0.12);
        }
        50% {
          box-shadow:
            inset 0 0 0 7px rgba(0, 0, 0, 0.28),
            inset 0 0 36px rgba(0, 0, 0, 0.34),
            0 24px 62px rgba(0, 0, 0, 0.55),
            0 0 42px rgba(57, 255, 136, 0.52),
            0 0 96px rgba(57, 255, 136, 0.22);
        }
      }

      @keyframes fallSpark {
        to {
          transform: translateY(110vh) rotate(560deg);
          opacity: 0;
        }
      }

      @media (max-width: 900px) {
        body {
          overflow: auto;
          background-attachment: scroll;
        }

        .top {
          padding-inline: 16px;
        }

        .brand {
          font-size: 13px;
        }

        .attempt {
          min-height: 38px;
          font-size: 13px;
        }

        .layout {
          min-height: auto;
          grid-template-columns: 1fr;
          gap: 18px;
          padding: 16px;
        }

        h1 {
          max-width: none;
          font-size: clamp(50px, 13vw, 76px);
        }

        .lead {
          max-width: none;
          font-size: 16px;
        }

        .top-gallery {
          gap: 8px;
          margin-bottom: 14px;
        }

        .wheel-card {
          padding: 16px;
          border-radius: 20px;
        }

        .wheel-wrap {
          width: min(92vw, 444px);
        }

        .slice-label {
          width: 46%;
          font-size: 15px;
          padding-right: 8px;
        }

        .hub {
          width: 92px;
          height: 92px;
          font-size: 13px;
        }
      }

      @media (max-width: 500px) {
        .top {
          align-items: stretch;
          flex-direction: column;
        }

        .brand,
        .attempt {
          justify-content: center;
        }

        .top-gallery .photo {
          border-radius: 11px;
        }

        .wheel-head {
          display: grid;
        }

        .slice-label {
          font-size: 13.5px;
          padding-right: 7px;
        }
      }
    </style>
  </head>
  <body>
    <main class="app">
      <header class="top">
        <div class="brand">Cadouri Personalizate MD</div>
        <div class="attempt" id="attemptText">1 încercare per client</div>
      </header>

      <section class="layout">
        <div class="intro">
          <div class="eyebrow">Campanie interactivă</div>
          <h1>Roata Norocului Auto</h1>
          <p class="lead">Învârte roata o singură dată și câștigă un bonus pentru comanda ta. Premiul este valabil doar dacă faci o comandă.</p>
          <div class="steps">
            <div class="step"><span>1</span> Alege produsul dorit și apoi învârte roata.</div>
            <div class="step"><span>2</span> Fă screenshot cu premiul și codul primit.</div>
            <div class="step"><span>3</span> Trimite poza în privat când plasezi comanda.</div>
          </div>
        </div>

        <div class="wheel-zone">
          <div class="wheel-card">
            <div class="top-gallery" aria-label="Produse personalizate">
              <div class="photo"><img src="assets/wheel-showcase-set.jpg" alt="Set auto personalizat în cutie" /></div>
              <div class="photo"><img src="assets/wheel-showcase-crystal.jpg" alt="Breloc cristal personalizat" /></div>
              <div class="photo"><img src="assets/wheel-showcase-wallet.jpg" alt="Portmoneu personalizat" /></div>
            </div>
            <div class="wheel-head">
              <strong>Premiul tău se oprește la indicator</strong>
              <div class="status" id="status">Disponibil acum</div>
            </div>
            <div class="wheel-wrap">
              <div class="pointer"></div>
              <div class="wheel" id="wheel">
                <div class="slice-label">-10%</div>
                <div class="slice-label">CUTIE</div>
                <div class="slice-label">2 BAT.</div>
                <div class="slice-label">PRINT</div>
                <div class="slice-label">CUTIE 20</div>
                <div class="slice-label">-5%</div>
                <div class="slice-label">LIVRARE</div>
                <div class="slice-label">CADOU</div>
              </div>
              <div class="hub">SPIN</div>
            </div>
            <div class="controls">
              <form class="lead-form" id="leadForm">
                <label>
                  Numele tău
                  <input id="nameInput" name="name" autocomplete="name" placeholder="Ex: Maria" required />
                </label>
                <label>
                  Telefon pentru confirmarea premiului
                  <input id="phoneInput" name="phone" autocomplete="tel" inputmode="tel" placeholder="Ex: 069 123 456" required />
                </label>
                <div class="form-error" id="formError">Completează numele și un număr de telefon valid.</div>
                <button type="submit">Continuă la roată</button>
                <div class="form-note">Datele sunt folosite doar pentru confirmarea premiului și a comenzii.</div>
              </form>
              <div class="lead-summary" id="leadSummary">Datele au fost salvate. Poți învârti roata.</div>
              <button id="spinBtn" disabled>Învârte roata</button>
              <div class="result" id="result">
                <span>Premiul tău pentru comandă</span>
                <strong id="resultTitle">Cutie cadou gratuită</strong>
                <b id="resultCode">CUTIE-GRATIS</b>
              </div>
              <a class="ig-link" id="igLink" href="https://ig.me/m/cadouri_personalizatemd" rel="noopener">Scrie-ne în privat pe Instagram</a>
              <div class="copy-hint" id="copyHint">Codul se copiază automat. Dacă nu se deschide conversația, se va deschide profilul nostru.</div>
              <div class="locked" id="locked">Ai folosit deja încercarea de pe acest telefon/browser. Păstrează screenshot-ul cu codul și trimite-l în privat când faci comanda.</div>
              <div class="note">Premiul se aplică doar la o comandă plasată. Oferta se confirmă în privat, în funcție de produs și disponibilitate.</div>
            </div>
          </div>
        </div>
      </section>
    </main>

    <script>
      const wheel = document.getElementById("wheel");
      const spinBtn = document.getElementById("spinBtn");
      const result = document.getElementById("result");
      const resultTitle = document.getElementById("resultTitle");
      const resultCode = document.getElementById("resultCode");
      const igLink = document.getElementById("igLink");
      const copyHint = document.getElementById("copyHint");
      const statusEl = document.getElementById("status");
      const locked = document.getElementById("locked");
      const attemptText = document.getElementById("attemptText");
      const leadForm = document.getElementById("leadForm");
      const nameInput = document.getElementById("nameInput");
      const phoneInput = document.getElementById("phoneInput");
      const formError = document.getElementById("formError");
      const leadSummary = document.getElementById("leadSummary");
      const STORAGE_KEY = "cadouri_personalizate_roata_universala_v3";
      const LEAD_STORAGE_KEY = "cadouri_personalizate_roata_lead_v1";
      const SHEET_WEB_APP_URL = "https://script.google.com/macros/s/AKfycbxru45Oq1F47haN_2s9xvsd0Nui20XMHcKPAJ-_psBCZebB3s6BMSPBLVsuza0xN5Dx/exec";
      const INSTAGRAM_DM = "https://ig.me/m/cadouri_personalizatemd";
      const INSTAGRAM_PROFILE = "https://www.instagram.com/cadouri_personalizatemd/";
      let leadData = null;

      const prizes = [
        { label: "Ai câștigat 10% reducere la comanda ta.", code: "COMANDA10", short: "-10%" },
        { label: "Ai câștigat o cutie cadou gratuită la comanda ta.", code: "CUTIE-GRATIS", short: "CUTIE" },
        { label: "Ai câștigat 2 baterii de rezervă la un breloc cristal comandat.", code: "2BATERII", short: "2 BATERII" },
        { label: "Ai câștigat imprimare gratuită la un breloc comandat.", code: "IMPRIMARE", short: "IMPRIMARE" },
        { label: "Ai câștigat cutia pentru breloc la doar 20 lei.", code: "CUTIE20", short: "CUTIE 20" },
        { label: "Ai câștigat 5% reducere la comanda ta.", code: "COMANDA5", short: "-5%" },
        { label: "Ai câștigat livrare redusă pentru comanda ta.", code: "LIVRARE", short: "LIVRARE" },
        { label: "Ai câștigat ambalare cadou gratuită la comanda ta.", code: "CADOU", short: "CADOU" },
      ];

      let rotation = 0;
      let spinning = false;

      function savePrize(data) {
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data));
      }

      function saveLead(data) {
        leadData = data;
        localStorage.setItem(LEAD_STORAGE_KEY, JSON.stringify(data));
      }

      function readSavedPrize() {
        try {
          return JSON.parse(localStorage.getItem(STORAGE_KEY));
        } catch {
          return null;
        }
      }

      function readSavedLead() {
        try {
          return JSON.parse(localStorage.getItem(LEAD_STORAGE_KEY));
        } catch {
          return null;
        }
      }

      function normalizePhone(phone) {
        return phone.replace(/[^\d+]/g, "");
      }

      function isValidLead(name, phone) {
        return name.trim().length >= 2 && normalizePhone(phone).replace(/[^\d]/g, "").length >= 7;
      }

      function showLeadReady(data) {
        leadForm.classList.add("hidden");
        leadSummary.textContent = `${data.name}, datele au fost salvate. Poți învârti roata.`;
        leadSummary.classList.add("show");
        spinBtn.disabled = false;
        statusEl.textContent = "Date salvate";
      }

      function sendLead(eventType, extra = {}) {
        if (!SHEET_WEB_APP_URL || !leadData) return;
        const body = new URLSearchParams({
          eventType,
          name: leadData.name,
          phone: leadData.phone,
          prize: extra.prize || "",
          code: extra.code || "",
          page: window.location.href,
          createdAt: new Date().toISOString(),
          userAgent: navigator.userAgent,
        });

        fetch(SHEET_WEB_APP_URL, {
          method: "POST",
          mode: "no-cors",
          body,
        }).catch(() => {});
      }

      function showPrize(prize, savedRotation, alreadyPlayed = false) {
        resultTitle.textContent = prize.label;
        resultCode.textContent = prize.code;
        result.classList.add("show");
        igLink.classList.add("show");
        copyHint.classList.add("show");
        rotation = savedRotation || rotation;
        wheel.style.transition = alreadyPlayed ? "none" : "";
        wheel.style.transform = `rotate(${rotation}deg)`;
        if (alreadyPlayed) {
          spinBtn.disabled = true;
          spinBtn.textContent = "Încercare folosită";
          statusEl.textContent = "Cod deja generat";
          attemptText.textContent = "Ai deja un cod";
          locked.classList.add("show");
        }
      }

      function celebrate() {
        const colors = ["#39ff88", "#ffffff", "#b8ffd4", "#0aff6c"];
        for (let i = 0; i < 42; i += 1) {
          const spark = document.createElement("span");
          spark.className = "spark";
          spark.style.left = `${Math.random() * 100}vw`;
          spark.style.background = colors[i % colors.length];
          spark.style.animationDelay = `${Math.random() * 0.18}s`;
          spark.style.transform = `rotate(${Math.random() * 180}deg)`;
          document.body.appendChild(spark);
          window.setTimeout(() => spark.remove(), 1700);
        }
      }

      function spin() {
        if (spinning || readSavedPrize() || !leadData) return;
        spinning = true;
        result.classList.remove("show");
        igLink.classList.remove("show");
        copyHint.classList.remove("show");
        locked.classList.remove("show");
        spinBtn.disabled = true;
        spinBtn.textContent = "Se învârte...";
        statusEl.textContent = "Se alege premiul";

        const winningIndex = Math.floor(Math.random() * prizes.length);
        const prize = prizes[winningIndex];
        const segment = 360 / prizes.length;
        const targetCenter = winningIndex * segment + segment / 2;
        const pointerAngle = 270;
        const fullTurns = 6 + Math.floor(Math.random() * 3);
        const targetRotation = fullTurns * 360 + pointerAngle - targetCenter;
        rotation += targetRotation;
        wheel.style.transition = "";
        wheel.style.transform = `rotate(${rotation}deg)`;

        window.setTimeout(() => {
          const saved = {
            prize,
            rotation,
            lead: leadData,
            playedAt: new Date().toISOString(),
          };
          savePrize(saved);
          showPrize(prize, rotation);
          sendLead("wheel_result", { prize: prize.label, code: prize.code });
          celebrate();
          spinBtn.disabled = true;
          spinBtn.textContent = "Încercare folosită";
          statusEl.textContent = "Fă screenshot";
          attemptText.textContent = "Codul tău este generat";
          locked.classList.add("show");
          spinning = false;
        }, 5150);
      }

      function init() {
        const savedLead = readSavedLead();
        if (savedLead && savedLead.name && savedLead.phone) {
          leadData = savedLead;
          showLeadReady(savedLead);
        }

        const saved = readSavedPrize();
        if (saved && saved.prize) {
          if (saved.lead) {
            leadData = saved.lead;
            showLeadReady(saved.lead);
          }
          showPrize(saved.prize, saved.rotation, true);
        }

        const params = new URLSearchParams(window.location.search);
        if (params.get("reset") === "1") {
          localStorage.removeItem(STORAGE_KEY);
          localStorage.removeItem(LEAD_STORAGE_KEY);
          window.location.href = window.location.pathname;
        }
      }

      leadForm.addEventListener("submit", (event) => {
        event.preventDefault();
        const name = nameInput.value.trim();
        const phone = phoneInput.value.trim();
        if (!isValidLead(name, phone)) {
          formError.classList.add("show");
          return;
        }

        formError.classList.remove("show");
        const data = {
          name,
          phone: normalizePhone(phone),
          savedAt: new Date().toISOString(),
        };
        saveLead(data);
        showLeadReady(data);
        sendLead("lead_submitted");
      });

      spinBtn.addEventListener("click", spin);
      igLink.addEventListener("click", async (event) => {
        event.preventDefault();
        const message = `Salut! Am câștigat la Roata Norocului: ${resultTitle.textContent} Cod: ${resultCode.textContent}. Vreau să plasez o comandă.`;
        try {
          await navigator.clipboard.writeText(message);
        } catch {
          // Clipboard access can be blocked in some browsers; the Instagram link still opens.
        }

        window.location.href = INSTAGRAM_DM;
        window.setTimeout(() => {
          window.location.href = INSTAGRAM_PROFILE;
        }, 1200);
      });
      init();
    </script>
  </body>
</html>
